{
  "manifest_version": 3,
  "name": "ViperLink for Schoology",
  "version": "1.0.0",
  "description": "Makes plain-text URLs in Schoology bios, descriptions, and posts clickable. Leaves existing links and editors untouched.",
  "author": "ViperShard",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.schoology.com/*",
        "*://schoology.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "viperlink@vipershard.dev",
      "strict_min_version": "109.0"
    }
  }
}
